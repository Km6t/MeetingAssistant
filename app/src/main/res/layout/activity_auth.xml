<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="会议助手云端登录"
            android:textColor="#073640"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="现在改为账号 + 邀请参会模式。登录后，不同设备会看到同一场会议。"
            android:textColor="#5B6B73"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/auth_server_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:hint="服务器地址，例如 http://159.75.95.19:8080"
            android:inputType="textUri"
            android:padding="12dp" />

        <EditText
            android:id="@+id/auth_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="用户名 / 学号"
            android:inputType="text"
            android:padding="12dp" />

        <EditText
            android:id="@+id/auth_display_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="显示名称（注册时填写）"
            android:inputType="textPersonName"
            android:padding="12dp" />

        <EditText
            android:id="@+id/auth_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="密码"
            android:inputType="textPassword"
            android:padding="12dp" />

        <TextView
            android:id="@+id/auth_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="请先登录或注册。"
            android:textColor="#5B6B73"
            android:textSize="14sp" />

        <Button
            android:id="@+id/auth_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:backgroundTint="#0B5563"
            android:text="登录"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/auth_register"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="注册并进入" />
    </LinearLayout>
</ScrollView>
