<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="共享会议基础信息"
            android:textColor="#073640"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/con_topic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="会议主题"
            android:padding="12dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/con_organizer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="当前组织者"
            android:padding="12dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/con_location_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="会议地点"
            android:padding="12dp"
            android:singleLine="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="开始时间"
            android:textColor="#073640"
            android:textSize="18sp"
            android:textStyle="bold" />

        <CalendarView
            android:id="@+id/con_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TimePicker
            android:id="@+id/con_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:timePickerMode="spinner" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="持续时长"
            android:textColor="#073640"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/con_hour"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="小时"
                android:inputType="number"
                android:padding="12dp" />

            <EditText
                android:id="@+id/con_min"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:hint="分钟"
                android:inputType="number"
                android:padding="12dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="提醒设置"
            android:textColor="#073640"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/con_reminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="签到位置校验"
            android:textColor="#073640"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/con_latitude"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="纬度"
                android:inputType="numberDecimal|numberSigned"
                android:padding="12dp" />

            <EditText
                android:id="@+id/con_longitude"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:hint="经度"
                android:inputType="numberDecimal|numberSigned"
                android:padding="12dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/con_radius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="签到半径（米）"
            android:inputType="number"
            android:padding="12dp" />

        <Button
            android:id="@+id/btn_fill_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="使用当前位置填充经纬度" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="邀请参会人"
            android:textColor="#073640"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/con_attendees"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="8dp"
            android:gravity="top|start"
            android:hint="每行一个用户名，例如 zhangsan。被邀请人登录后就能看到该会议。"
            android:inputType="textMultiLine"
            android:padding="12dp" />

        <Button
            android:id="@+id/add_submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#0B5563"
            android:text="保存共享会议"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>
